# ─── Copy to .env and fill in your values ───────────────────────────────────
# cp .env.example .env

# ─── Live feed selection ────────────────────────────────────────────────────
# alpaca       = poll all watchlist tickers from Alpaca (recommended)
# tradingview  = legacy CDP scraper (follows the active TradingView chart tab)
DATA_SOURCE=alpaca

# ─── Watchlist & chart settings ─────────────────────────────────────────────
TICKERS=NVDA,MU,INTC,AMD,TSM,AVGO,QQQ
TIMEFRAME=15m
CANDLE_BUFFER_SIZE=300

# Alpaca feed poll cadence (when DATA_SOURCE=alpaca)
ALPACA_BAR_POLL_MS=15000
ALPACA_TRADE_POLL_MS=3000

# TradingView CDP scraper (when DATA_SOURCE=tradingview)
CDP_URL=http://localhost:9222
POLL_INTERVAL_MS=3000

# ─── Signal quality & trade limits ────────────────────────────────────────────
MIN_CONFIDENCE=70
# Log "👀 chance" when confluence reaches this score but doesn't fire.
# Default = MIN_CONFIDENCE - 15
OPPORTUNITY_THRESHOLD=55
MIN_RR_RATIO=2.5
TARGET_PROFIT_USD=50
MAX_TRADES_PER_DAY=5
MAX_CONCURRENT=2

# AGGRESSIVE=true  → looser filters, more signals (higher frequency)
# AGGRESSIVE=false → strict A-grade setups only (default)
AGGRESSIVE=false

# Sharia-compliant mode: long-only spot, no shorting, no margin (default: true)
SHARIA_COMPLIANT=true

# ─── Portfolio & position management ────────────────────────────────────────
# Alpaca is the source of truth for open positions.
# portfolio.json is optional — use it for per-ticker SL/TP overrides only.
PORTFOLIO_FILE=./portfolio.json
DEFAULT_STOP_PCT=0.03
DEFAULT_TP1_PCT=0.03
DEFAULT_TP2_PCT=0.06

# ─── Session / extended hours ───────────────────────────────────────────────
# Enable Alpaca 24/5 overnight trading (20:00–03:50 ET, weeknights).
# Only ~120 select tickers supported (NVDA, AMD, INTC, MU, QQQ, AAPL, TSLA, SPY…).
ENABLE_OVERNIGHT=false

# ─── Alpaca Paper Trading ───────────────────────────────────────────────────
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_PAPER_KEY_ID=your_paper_key_id
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key
# true = submit paper orders | false = dry-run (log only)
ALPACA_AUTO_TRADE=false

# ─── News & fundamentals gates ──────────────────────────────────────────────
# News: Alpaca News API keyword scoring (+/- confluence)
ENABLE_NEWS_GATE=true
# Earnings: skip trades 4h before / 1h after scheduled reports (Yahoo calendar)
ENABLE_EARNINGS_GATE=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_DIR=./logs
